FROM php:8.2-apache

# Установка расширений PHP
RUN docker-php-ext-install mysqli pdo pdo_mysql

# Копирование всех файлов из корня
COPY . /var/www/html/

# Настройка прав
RUN chown -R www-www-data /var/www/html && \
    chmod -R 755 /var/www/html

# Порт для Railway
EXPOSE 80

# Запуск Apache
CMD ["apache2-foreground"]
